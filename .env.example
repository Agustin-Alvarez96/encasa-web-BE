# Base de datos (Supabase)
DB_URL=jdbc:postgresql://[host].supabase.com:5432/postgres
DB_USER=postgres.[project-id]
DB_PASS=tu-password-de-supabase

# JWT — generá un secret con: openssl rand -base64 64
JWT_SECRET=tu-jwt-secret-de-al-menos-256-bits
JWT_EXPIRATION=2592000000

# CORS — URL del frontend en Vercel (sin trailing slash)
ALLOWED_ORIGINS=https://tu-proyecto.vercel.app

# Modo de DB (no cambiar en producción)
DDL_AUTO=update

# Puerto (Railway lo setea automáticamente)
PORT=8080
